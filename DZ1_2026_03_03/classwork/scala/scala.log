//Агрегации и shuffle

scala> val data = Seq(
     |   ("user1","A",100),
     |   ("user1","B",200),
     |   ("user2","A",50)
     | )
data: Seq[(String, String, Int)] = List((user1,A,100), (user1,B,200), (user2,A,50))

scala> val df = spark.createDataFrame(data).toDF("user","category","amount")
df: org.apache.spark.sql.DataFrame = [user: string, category: string ... 1 more field]

scala> df.groupBy("user").sum("amount").show()
+-----+-----------+
| user|sum(amount)|
+-----+-----------+
|user1|        300|
|user2|         50|
+-----+-----------+



//Join и broadcast

scala> val users = Seq(
     |   ("user1","Berlin"),
     |   ("user2","Munich")
     | ).toDF("user","city")
users: org.apache.spark.sql.DataFrame = [user: string, city: string]

scala> val orders = Seq(
     |   ("user1",100),
     |   ("user1",50),
     |   ("user2",300)
     | ).toDF("user","amount")
orders: org.apache.spark.sql.DataFrame = [user: string, amount: int]

scala> users.join(orders, "user").show()
+-----+------+------+
| user|  city|amount|
+-----+------+------+
|user1|Berlin|    50|
|user1|Berlin|   100|
|user2|Munich|   300|
+-----+------+------+

scala> import org.apache.spark.sql.functions.broadcast
import org.apache.spark.sql.functions.broadcast

scala> broadcast(users).join(orders, "user").show()
+-----+------+------+
| user|  city|amount|
+-----+------+------+
|user1|Berlin|   100|
|user1|Berlin|    50|
|user2|Munich|   300|
+-----+------+------+



