//RDD vs DataFrame
%spark.pyspark
rdd = sc.parallelize([1,2,3,4,5])
rdd.map(lambda x: x * 2).collect()
[2, 4, 6, 8, 10]

df = spark.createDataFrame([(1,), (2,), (3,)], ["value"])
df.selectExpr("value * 2 as value").show()
+-----+
|value|
+-----+
|    2|
|    4|
|    6|
+-----+


